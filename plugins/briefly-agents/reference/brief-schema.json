{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Creative Brief",
  "type": "object",
  "required": [
    "brand",
    "products"
  ],
  "$defs": {
    "visualDirection": {
      "type": "object",
      "required": [
        "color_world",
        "lighting_signature",
        "model_direction",
        "prop_styling",
        "environment_surface_direction",
        "mood"
      ],
      "properties": {
        "color_world": {
          "type": "string",
          "maxLength": 380
        },
        "lighting_signature": {
          "type": "string",
          "maxLength": 380
        },
        "model_direction": {
          "type": "string",
          "maxLength": 380
        },
        "prop_styling": {
          "type": "string",
          "maxLength": 380
        },
        "environment_surface_direction": {
          "type": "string",
          "maxLength": 380
        },
        "mood": {
          "type": "string",
          "maxLength": 380
        }
      }
    },
    "shotOptionArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "option_id",
          "prompt",
          "lighting",
          "shadows",
          "surface_material",
          "color_temperature",
          "aspect_ratio",
          "fits_deliverables"
        ],
        "properties": {
          "option_id": {
            "type": "string"
          },
          "prompt": {
            "type": "string"
          },
          "lighting": {
            "type": "string"
          },
          "shadows": {
            "type": "string"
          },
          "surface_material": {
            "type": "string"
          },
          "color_temperature": {
            "type": "string"
          },
          "aspect_ratio": {
            "type": "string"
          },
          "resolution": {
            "type": "string"
          },
          "camera": {
            "type": [
              "string",
              "null"
            ]
          },
          "fits_deliverables": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "copyBlock": {
    "type": [
      "object",
      "null"
    ],
    "description": "Unified copy block. Select only fields applicable to the image type and visual concept. Not all fields are required — an image may have just a heading and subheading with no bullet points.",
    "properties": {
      "heading": {
        "type": [
          "string",
          "null"
        ],
        "description": "Hero headline or main hook. Bold, benefit-driven statement that captures attention in under 2 seconds.",
        "maxLength": 80
      },
      "subheading": {
        "type": [
          "string",
          "null"
        ],
        "description": "Supporting context, emotional appeal, or explanation of the 'how'. Max 1-2 concise sentences.",
        "maxLength": 250
      },
      "bullet_points": {
        "type": [
          "array",
          "null"
        ],
        "description": "Specific technical callouts, specs, proof points, or trust signals. Fragment sentences preferred. Select from: technical specs, dimensions/capacity, material/construction, usage/compatibility, safety/certifications, maintenance/care, social proof, environmental impact, performance metrics — only what is applicable.",
        "maxItems": 5,
        "items": {
          "type": "string",
          "maxLength": 100
        }
      }
    }
  },
  "properties": {
    "brand": {
      "type": "object",
      "required": [
        "name",
        "guidelines"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "website": {
          "type": [
            "string",
            "null"
          ]
        },
        "guidelines": {
          "type": "object",
          "required": [
            "colors",
            "typography",
            "tone_of_voice",
            "brand_descriptors",
            "target_demographic"
          ],
          "properties": {
            "colors": {
              "type": "object",
              "required": [
                "primary"
              ],
              "properties": {
                "primary": {
                  "type": "string"
                },
                "secondary": {
                  "type": "string"
                },
                "accent": {
                  "type": "string"
                },
                "additional": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "typography": {
              "type": "object",
              "properties": {
                "heading_font": {
                  "type": "string"
                },
                "body_font": {
                  "type": "string"
                }
              }
            },
            "tone_of_voice": {
              "type": "string"
            },
            "brand_descriptors": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 3,
              "maxItems": 3
            },
            "target_demographic": {
              "type": "string"
            },
            "hard_rules": {
              "type": "object",
              "properties": {
                "dos": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "donts": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "products": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "asin",
          "type",
          "research",
          "creative_direction",
          "deliverables",
          "shot_list"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "asin": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "existing",
              "new"
            ]
          },
          "research": {
            "type": "object",
            "required": [
              "product",
              "competitors",
              "keywords",
              "gap_analysis"
            ],
            "properties": {
              "product": {
                "type": "object",
                "required": [
                  "image_urls",
                  "usps"
                ],
                "properties": {
                  "description": {
                    "type": "string"
                  },
                  "price": {
                    "type": "string"
                  },
                  "rating": {
                    "type": "string"
                  },
                  "image_urls": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "minItems": 1
                  },
                  "usps": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "minItems": 1
                  },
                  "complaints": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              },
              "competitors": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "name",
                    "asin",
                    "image_urls",
                    "intersecting_keywords",
                    "avg_position"
                  ],
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "asin": {
                      "type": "string"
                    },
                    "url": {
                      "type": "string"
                    },
                    "price": {
                      "type": "string"
                    },
                    "rating": {
                      "type": "string"
                    },
                    "image_urls": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "minItems": 1
                    },
                    "intersecting_keywords": {
                      "type": [
                        "number",
                        "null"
                      ]
                    },
                    "avg_position": {
                      "type": [
                        "number",
                        "null"
                      ]
                    },
                    "usps": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "complaints": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              "keywords": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "keyword",
                    "average_monthly_search_volume"
                  ],
                  "properties": {
                    "keyword": {
                      "type": "string"
                    },
                    "average_monthly_search_volume": {
                      "type": "number"
                    }
                  }
                }
              },
              "visual_implication": {
                "type": "string",
                "maxLength": 400
              },
              "gap_analysis": {
                "type": "object",
                "required": [
                  "visual_patterns",
                  "differentiation_opportunities",
                  "complaints_to_address"
                ],
                "properties": {
                  "visual_patterns": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "maxLength": 200
                    },
                    "minItems": 1
                  },
                  "differentiation_opportunities": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "maxLength": 200
                    },
                    "minItems": 1
                  },
                  "complaints_to_address": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "maxLength": 200
                    },
                    "minItems": 1
                  }
                }
              }
            }
          },
          "creative_direction": {
            "type": "object",
            "required": [
              "positioning_statement",
              "key_messages",
              "visual_direction",
              "competitive_differentiation"
            ],
            "properties": {
              "positioning_statement": {
                "type": "string",
                "maxLength": 500
              },
              "key_messages": {
                "type": "array",
                "items": {
                  "type": "string",
                  "maxLength": 250
                }
              },
              "visual_direction": {
                "$ref": "#/$defs/visualDirection"
              },
              "competitive_differentiation": {
                "type": "string",
                "maxLength": 500
              }
            }
          },
          "deliverables": {
            "type": "object",
            "properties": {
              "main_image": {
                "type": [
                  "array",
                  "null"
                ],
                "minItems": 5,
                "maxItems": 5,
                "items": {
                  "type": "object",
                  "required": [
                    "version_number",
                    "strategy_name",
                    "feature",
                    "strategy",
                    "visual_concept"
                  ],
                  "properties": {
                    "version_number": {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 5
                    },
                    "strategy_name": {
                      "type": "string"
                    },
                    "feature": {
                      "type": "string"
                    },
                    "strategy": {
                      "type": "string",
                      "maxLength": 320
                    },
                    "visual_concept": {
                      "type": "string",
                      "maxLength": 400
                    }
                  }
                }
              },
              "listing_images": {
                "type": [
                  "object",
                  "null"
                ],
                "required": [
                  "sequence_strategy",
                  "images"
                ],
                "properties": {
                  "sequence_strategy": {
                    "type": "string",
                    "maxLength": 400
                  },
                  "images": {
                    "type": "array",
                    "minItems": 7,
                    "maxItems": 7,
                    "items": {
                      "type": "object",
                      "required": [
                        "slot_number",
                        "role_in_sequence",
                        "image_type",
                        "visual_concept",
                        "strategy"
                      ],
                      "properties": {
                        "slot_number": {
                          "type": "integer",
                          "minimum": 1,
                          "maximum": 7
                        },
                        "role_in_sequence": {
                          "type": "string",
                          "enum": [
                            "Opening",
                            "Middle",
                            "Closing"
                          ]
                        },
                        "image_type": {
                          "type": "string",
                          "enum": [
                            "full_bleed",
                            "infographic"
                          ]
                        },
                        "visual_concept": {
                          "type": "string"
                        },
                        "copy": {
                          "$ref": "#/$defs/copyBlock"
                        },
                        "strategy": {
                          "type": "string",
                          "maxLength": 320
                        }
                      }
                    }
                  }
                }
              },
              "aplus": {
                "type": [
                  "object",
                  "null"
                ],
                "required": [
                  "modules"
                ],
                "properties": {
                  "modules": {
                    "type": "array",
                    "minItems": 6,
                    "maxItems": 6,
                    "items": {
                      "type": "object",
                      "required": [
                        "module_number",
                        "module_role",
                        "dimensions",
                        "visual_concept",
                        "copy",
                        "strategy",
                        "wireframe_description"
                      ],
                      "properties": {
                        "module_number": {
                          "type": "integer",
                          "minimum": 1,
                          "maximum": 6
                        },
                        "module_role": {
                          "type": "string",
                          "enum": [
                            "hero_with_icons",
                            "expand_or_deepen",
                            "new_territory",
                            "bridge_to_close",
                            "brand_closing"
                          ]
                        },
                        "dimensions": {
                          "type": "string",
                          "enum": [
                            "1464x1200",
                            "1464x600"
                          ]
                        },
                        "visual_concept": {
                          "type": "string"
                        },
                        "copy": {
                          "$ref": "#/$defs/copyBlock"
                        },
                        "strategy": {
                          "type": "string",
                          "maxLength": 320
                        },
                        "wireframe_description": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "shot_list": {
            "type": [
              "object",
              "null"
            ],
            "required": [
              "visual_dna",
              "shots_by_type"
            ],
            "properties": {
              "visual_dna": {
                "$ref": "#/$defs/visualDirection"
              },
              "shots_by_type": {
                "type": "object",
                "properties": {
                  "studio_plain": {
                    "$ref": "#/$defs/shotOptionArray"
                  },
                  "studio_styled": {
                    "$ref": "#/$defs/shotOptionArray"
                  },
                  "lifestyle_tight": {
                    "$ref": "#/$defs/shotOptionArray"
                  },
                  "lifestyle_wide": {
                    "$ref": "#/$defs/shotOptionArray"
                  },
                  "action_wide": {
                    "$ref": "#/$defs/shotOptionArray"
                  },
                  "action_tight": {
                    "$ref": "#/$defs/shotOptionArray"
                  },
                  "group_kit": {
                    "$ref": "#/$defs/shotOptionArray"
                  },
                  "packaging": {
                    "$ref": "#/$defs/shotOptionArray"
                  },
                  "detail_closeup": {
                    "$ref": "#/$defs/shotOptionArray"
                  }
                },
                "additionalProperties": false
              }
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "generated_date": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "agency_name": {
          "type": "string"
        },
        "phases_completed": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        }
      }
    }
  }
}